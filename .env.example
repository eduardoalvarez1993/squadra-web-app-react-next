# Copie este arquivo para .env.local e preencha os valores antes de iniciar o servidor
# cp .env.example .env.local

# Segredo de sessão — gerar com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# URL base da API da Squadra
SQUADRA_API_URL=https://api.squadra.com.br/api

# URL pública da aplicação (sem trailing slash)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting via Upstash Redis — opcional em dev, obrigatório em prod
# Criar banco em https://upstash.com (free tier)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Timeout do cliente HTTP para a Squadra API (ms) — padrão: 15000
SQUADRA_API_TIMEOUT_MS=15000
